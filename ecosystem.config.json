{
  "apps": [
    {
      "name": "phonedesk-backend",
      "script": "dist/server.js",
      "cwd": "./backend",
      "instances": 1,
      "autorestart": true,
      "watch": false,
      "max_memory_restart": "1G",
      "env": {
        "NODE_ENV": "production"
      }
    },
    {
      "name": "phonedesk-frontend",
      "script": "node_modules/.bin/next",
      "args": "start",
      "cwd": "./frontend",
      "instances": 1,
      "autorestart": true,
      "watch": false,
      "max_memory_restart": "1G",
      "env": {
        "NODE_ENV": "production",
        "PORT": 3000
      }
    }
  ]
}
